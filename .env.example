# Hugging Face — required to download Voxtral TTS weights (accept license on the model card first)
# https://huggingface.co/mistralai/Voxtral-4B-TTS-2603
HF_TOKEN=

# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434
# OpenRouter (OpenAI-compatible); use outline_provider/transcript_provider: openrouter in episodes.json
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional for OpenRouter dashboard attribution:
# OPENROUTER_HTTP_REFERER=https://github.com/your/repo
# OPENROUTER_X_TITLE=podcast-generator

# TTS
ELEVENLABS_API_KEY=
VOXTRAL_LOCAL_URL=http://127.0.0.1:8000
# Apple Silicon — third-party MLX Voxtral (Mistral-TTS-iOS); see docs/voxtral-local-setup.md
# VOXTRAL_MLX_ROOT=/path/to/Mistral-TTS-iOS
# VOXTRAL_MLX_MODEL_PATH=/path/to/Mistral-TTS-iOS/mlx_model_q4
# Mistral cloud TTS (Voxtral) — see docs/tts-providers.md
# Use API root (…/v1) or bare https://api.mistral.ai — not the full …/audio/speech URL
MISTRAL_TTS_BASE_URL=https://api.mistral.ai/v1

# Langfuse — self-host (default) or cloud
# Local: run Langfuse via Docker (see docs/langfuse-local.md), then:
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Cloud Langfuse: set LANGFUSE_HOST=https://cloud.langfuse.com and keys from the cloud project

# Runtime
TTS_BATCH_SIZE=5
PODCAST_RETRY_MAX_ATTEMPTS=3
PODCAST_RETRY_WAIT_MULTIPLIER=5
PODCAST_RETRY_WAIT_MAX=30
